{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structural-explainability.org/accountable-record/schemas/elements/conformance/expected-report.schema.json",
  "title": "Expected Report",
  "type": "object",
  "required": [
    "element_type_id",
    "element_instance_id",
    "fixture",
    "expected_outcomes"
  ],
  "properties": {
    "element_type_id": {
      "const": "se.accountable-record.conformance.expected-report"
    },
    "element_instance_id": {
      "type": "string"
    },
    "fixture": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "verifier": {
      "type": "string"
    },
    "expected_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "outcome"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "comparison_scope": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
