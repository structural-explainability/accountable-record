{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structural-explainability.org/accountable-record/schemas/elements/claims/claim-shape.schema.json",
  "title": "Claim Shape",
  "type": "object",
  "required": [
    "element_type_id",
    "element_instance_id",
    "value",
    "label"
  ],
  "properties": {
    "element_type_id": {
      "const": "se.accountable-record.claims.claim-shape"
    },
    "element_instance_id": {
      "type": "string"
    },
    "value": {
      "type": "string",
      "enum": [
        "bundle_field_predicate",
        "record_field_predicate",
        "cross_reference_predicate",
        "trait_conformance",
        "custom"
      ]
    },
    "label": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
